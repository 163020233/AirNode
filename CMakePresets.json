{
    "version": 3,
    "configurePresets": [
        {
            "name": "airnode-default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "toolchainFile": "${sourceDir}/cmake/gcc-arm-none-eabi.cmake",
            "cacheVariables": {
            }
        },
        {
            "name": "airnode-debug",
            "inherits": "airnode-default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "airnode-release",
            "inherits": "airnode-default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "airnode-debug",
            "configurePreset": "airnode-debug"
        },
        {
            "name": "airnode-release",
            "configurePreset": "airnode-release"
        }
    ]
}
